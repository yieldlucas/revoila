# --- Règles métier (DÉFAUTS ; surchargeables par restaurant dans data/restaurants.json) ---
WINBACK_DAYS=45          # jours d'inactivité avant de considérer un client "endormi"
MIN_VISITS=2             # nombre minimum de visites pour être relancé
COOLDOWN_DAYS=30         # délai minimum entre deux relances d'un même client

# --- Estimation ROI (défauts) ---
AVG_TICKET=35            # panier moyen en euros
WINBACK_CONVERSION=0.15  # taux de retour estimé d'une relance (15%)

# --- IA (optionnel) ---
# Laisse vide pour le mode template (aucun appel API).
ANTHROPIC_API_KEY=

# --- Envois ---
# DRY_RUN=true : on logge sans rien envoyer (sécurité). Passe à false pour de vrais envois.
DRY_RUN=true

# Email (Brevo / ex-Sendinblue)
BREVO_API_KEY=
EMAIL_FROM=contact@ton-resto.fr
EMAIL_FROM_NAME=Ton Resto

# SMS : "brevo", "twilio" ou "none"
SMS_PROVIDER=none
SMS_SENDER=Resto
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# URL publique (pour les liens de désinscription dans les messages)
PUBLIC_BASE_URL=http://localhost:8000
